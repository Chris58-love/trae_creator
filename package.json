{
  "name": "civicmate-demo",
  "version": "0.0.0",
  "private": true,
  "description": "CivicMate 办事不跑空 - AI 材料预审与陪办助手（第 2 轮：广东县级行政区划）",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c green,cyan \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "selfcheck": "tsx server/review-selfcheck.ts",
    "identify-selfcheck": "tsx server/identify-selfcheck.ts",
    "identify-http-selfcheck": "tsx server/identify-http-selfcheck.ts",
    "ark-selfcheck": "tsx server/ark-selfcheck.ts",
    "live-ai-smoke": "tsx server/live-ai-smoke.ts",
    "ai-status-selfcheck": "tsx server/ai-status-selfcheck.ts",
    "demo-flow-selfcheck": "tsx server/demo-flow-selfcheck.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
