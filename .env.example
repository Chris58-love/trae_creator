# CivicMate Demo 环境变量占位（不要在此填写真实密钥）
# 复制为 .env 并填入真实值后使用；.env 已被 .gitignore 忽略。

# DeepSeek（政务规则解释 / 材料审查 / 文本 fallback）
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Ark 豆包视觉模型（图片材料识别，火山方舟 Responses API）
# ARK_API_KEY 由用户自行填写
# ARK_BASE_URL 默认指向火山方舟北京区
# ARK_MODEL 默认 doubao-seed-2-1-pro-260628
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-1-pro-260628

# 服务端口
PORT=3001
